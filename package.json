    "react-router-dom": "^6.28.0",
    "tailwindcss": "^4.1.18",
    "tinacms": "^3.7.0",
    "tinacms-authjs": "^21.0.0",
    "tinacms-gitprovider-github": "^4.1.0",
    "upstash-redis-level": "^1.1.1"
  },
  "devDependencies": {
