{
    "rewrites": [
        {
            "source": "/api/tina/:path*",
            "destination": "/api/tina/:path*"
        },
        {
            "source": "/admin/:path*",
            "destination": "/admin/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
