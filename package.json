{
  "name": "lectures-after-dark",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "npx eslint",
    "lint:fix": "npx eslint --fix --max-warnings 0",
    "type-check": "npx tsc --noEmit --pretty",
    "check": "pnpm run lint:fix && pnpm run type-check && pnpm run build",
    "preview": "vite preview",
    "strapi:dev": "pnpm --dir strapi run develop",
    "strapi:build": "pnpm --dir strapi run build",
    "strapi:start": "pnpm --dir strapi run start",
    "strapi:seed": "pnpm --dir strapi run seed",
    "workers:dev": "wrangler dev",
    "workers:deploy": "wrangler deploy"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "workerd"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wrangler": "^4.77.0"
  }
}
